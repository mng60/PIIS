generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  full_name         String
  role              Role      @default(user)
  avatar_url        String?
  xp                Int       @default(0)
  is_banned         Boolean   @default(false)
  chat_muted_until  DateTime?
  play_banned_until DateTime?
  pending_warning   String?   @db.VarChar(800)
  abandon_count     Int       @default(0)
  last_seen         DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
}

enum Role {
  user
  empresa
  admin
}

// ─── Games ───────────────────────────────────────────────────────────────────

model Game {
  id               String       @id @default(cuid())
  title            String
  description      String?
  full_description String?
  category         GameCategory
  thumbnail        String?
  game_type        GameType
  game_url         String?
  game_code        String?
  html_content     String?
  plays_count      Int          @default(0)
  rating_sum       Float        @default(0)
  rating_count     Int          @default(0)
  is_featured      Boolean      @default(false)
  is_active        Boolean      @default(true)
  is_adult         Boolean      @default(false)
  is_multiplayer      Boolean      @default(false)
  show_leaderboard    Boolean      @default(true)
  show_achievements   Boolean      @default(true)
  xp_per_play         Int          @default(10)
  elo_enabled           Boolean      @default(false)
  elo_k_factor          Int          @default(32)
  elo_min_rating        Int          @default(0)
  elo_position_points   String?      // JSON: puntos por posición para 3+ jugadores, ej: "[20,10,-5,-15]"
  publisher           String?
  created_by       String?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
}

enum GameCategory {
  accion
  puzzle
  arcade
  estrategia
}

enum GameType {
  html5
  lua
  builtin
}

// ─── Comments ────────────────────────────────────────────────────────────────

model Comment {
  id         String   @id @default(cuid())
  game_id    String
  user_email String
  user_name  String
  content    String
  rating     Float?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ─── User Game Stats ──────────────────────────────────────────────────────────
// Una fila por usuario+juego. Se actualiza en cada partida (upsert).
// Reemplaza la tabla Score, que crecía sin límite.

model UserGameStats {
  id          String   @id @default(cuid())
  user_email  String
  user_name   String
  game_id     String
  plays_count  Int      @default(0)
  best_score   Float    @default(0)
  last_score   Float    @default(0)
  wins_count   Int      @default(0)
  total_score  Float    @default(0)
  time_played  Int      @default(0)
  elo_rating   Int      @default(1200)
  elo_games    Int      @default(0)
  last_played  DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([user_email, game_id])
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  game_id    String
  user_email String
  created_at DateTime @default(now())

  @@unique([game_id, user_email])
}

// ─── Tournaments ─────────────────────────────────────────────────────────────

model Tournament {
  id               String            @id @default(cuid())
  title            String
  description      String?
  game_id          String
  start_date       DateTime
  end_date         DateTime
  prize            String?
  thumbnail        String?
  max_participants Int?
  status                TournamentStatus  @default(upcoming)
  is_active             Boolean           @default(true)
  created_by            String?           // email del creador (admin o empresa)
  elo_min               Int?              // ELO mínimo para inscribirse (null = sin restricción)
  elo_max               Int?              // ELO máximo para inscribirse (null = sin restricción)
  position_elo_points   String?           // JSON: puntos ELO por posición final, ej "[100,40,10,10,-15,-15,-25,-25]"
  tournament_k_multiplier Float           @default(1.5) // multiplicador del K-factor para partidas del torneo
  activated_at          DateTime?
  room_time_minutes     Int?              // Duración máxima de cada sala en minutos (null = sin límite)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
}

model TournamentParticipant {
  id            String   @id @default(cuid())
  tournament_id String
  user_email    String
  user_name     String
  elo_at_signup Int      @default(1200)
  bracket_name  String   @default("Principiante")
  joined_at     DateTime @default(now())

  @@unique([tournament_id, user_email])
}

model TournamentMatch {
  id                  String      @id @default(cuid())
  tournament_id       String
  bracket_name        String
  round               Int
  match_index         Int
  player1_email       String?
  player1_name        String?
  player2_email       String?
  player2_name        String?
  winner_email        String?
  room_code           String?
  status              MatchStatus @default(pending)
  player1_joined_at   DateTime?
  player2_joined_at   DateTime?
  forfeit_after       DateTime?
  created_at          DateTime    @default(now())
  updated_at          DateTime    @updatedAt

  @@index([tournament_id])
  @@index([room_code])
}

enum MatchStatus {
  pending
  playing
  finished
  bye
}

enum TournamentStatus {
  upcoming
  active
  finished
}

// ─── Achievements ────────────────────────────────────────────────────────────

model AchievementDefinition {
  id            String             @id @default(cuid())
  game_id       String?
  title         String
  description   String?
  icon_url      String?
  metric        AchievementMetric
  threshold     Float
  win_score_min Float?
  score_scale   Float              @default(1)
  score_offset  Float              @default(0)
  rarity        AchievementRarity  @default(bronze)
  is_active     Boolean            @default(true)
  sort_order    Int                @default(0)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
}

enum AchievementRarity {
  bronze
  silver
  gold
}

enum AchievementMetric {
  plays_count
  best_score
  wins_count
  single_run_score
}

model UserAchievement {
  id             String   @id @default(cuid())
  achievement_id String
  user_email     String
  game_id        String?
  progress       Float    @default(0)
  unlocked       Boolean  @default(false)
  unlocked_date  DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([achievement_id, user_email])
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatMessage {
  id         String   @id @default(cuid())
  game_id    String
  session_id String
  user_email String
  user_name  String
  message    String   @db.VarChar(300)
  created_at DateTime @default(now())
}

// ─── Game Sessions (generic multiplayer rooms) ────────────────────────────────
// Use this for any multiplayer game. host = player who created the room,
// guest = player who joined. game_state stores any JSON your game needs.
// current_turn: "host" | "guest" | any string your game uses.

model GameSession {
  id            String        @id @default(cuid())
  room_code     String        @unique
  game_id       String
  host_email    String
  host_name     String
  guest_email   String?
  guest_name    String?
  game_state    Json          @default("{}")
  current_turn  String        @default("host")
  winner        String?
  status        SessionStatus @default(waiting)
  game_mode     String        @default("normal")
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
}

enum SessionStatus {
  waiting
  playing
  finished
}

// ─── Chess Rooms ─────────────────────────────────────────────────────────────

model ChessRoom {
  id               String      @id @default(cuid())
  room_code        String      @unique
  host_email       String
  host_name        String
  host_avatar_url  String?
  host_elo         Int         @default(1200)
  guest_email      String?
  guest_name       String?
  guest_avatar_url String?
  elo_processed    Boolean     @default(false)
  game_mode        String      @default("normal")
  status           ChessStatus @default(waiting)
  current_turn     TurnColor   @default(white)
  board_state      String
  winner           String?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt
}

enum ChessStatus {
  waiting
  playing
  finished
}

enum TurnColor {
  white
  black
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model Report {
  id                  String        @id @default(cuid())
  target_kind         ReportTarget
  target_id           String
  game_id             String
  session_id          String?
  context_text        String?
  reporter_email      String
  reporter_name       String?
  reported_user_email String
  reported_user_name  String?
  reason              ReportReason
  details             String?       @db.VarChar(800)
  target_text         String        @db.VarChar(800)
  status              ReportStatus  @default(open)
  admin_action        AdminAction   @default(none)
  action_until        DateTime?
  admin_notes         String?       @db.VarChar(800)
  handled_by          String?
  handled_date        DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
}

enum ReportTarget {
  chat_message
  comment
}

enum ReportReason {
  spam
  insultos
  acoso
  contenido_sexual
  info_personal
  otro
}

enum ReportStatus {
  open
  reviewing
  resolved
  dismissed
}

enum AdminAction {
  none
  warn
  mute_chat
  ban_play
  ban_account
  delete_content
}

// ─── Social ──────────────────────────────────────────────────────────────────

model Friendship {
  id             String           @id @default(cuid())
  sender_email   String
  receiver_email String
  status         FriendshipStatus @default(pending)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  @@unique([sender_email, receiver_email])
}

enum FriendshipStatus {
  pending
  accepted
  rejected
}

model Block {
  id            String   @id @default(cuid())
  blocker_email String
  blocked_email String
  created_at    DateTime @default(now())

  @@unique([blocker_email, blocked_email])
}

model Notification {
  id         String           @id @default(cuid())
  user_email String
  type       NotificationType
  from_email String
  from_name  String
  is_read    Boolean          @default(false)
  data       Json             @default("{}")
  created_at DateTime         @default(now())
}

enum NotificationType {
  friend_request
  friend_accepted
  game_invite
}

// ─── Direct Messages ─────────────────────────────────────────────────────────

model DirectMessage {
  id             String   @id @default(cuid())
  sender_email   String
  receiver_email String
  message        String   @db.VarChar(1000)
  is_read        Boolean  @default(false)
  created_at     DateTime @default(now())

  @@index([sender_email, receiver_email])
  @@index([receiver_email, is_read])
}

// ─── Password Reset Tickets ───────────────────────────────────────────────────

model PasswordResetTicket {
  id          String       @id @default(cuid())
  user_email  String
  user_name   String?
  status      TicketStatus @default(open)
  resolved_by String?
  resolved_at DateTime?
  created_at  DateTime     @default(now())
}

enum TicketStatus {
  open
  resolved
}
