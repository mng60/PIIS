# PostgreSQL - Neon connection string
# Obtén este valor desde tu dashboard en neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT - pon aquí una cadena aleatoria larga y secreta
JWT_SECRET="cambia-esto-por-un-secreto-seguro"

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5173"

# Puerto del servidor (Railway lo sobreescribe automáticamente)
PORT=3001
